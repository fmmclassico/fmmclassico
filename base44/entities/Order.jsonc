{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Unique order number"
    },
    "items": {
      "type": "array",
      "description": "Order items",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "product_image": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          }
        }
      }
    },
    "total_amount": {
      "type": "number",
      "description": "Total order amount"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending_payment",
        "paid",
        "failed",
        "cancelled",
        "refunded"
      ],
      "default": "pending_payment",
      "description": "Payment status. CRITICAL: Controlled ONLY by Hubtel verification (callback or status check). NEVER set to 'paid' without Hubtel confirmation. Orders with payment_status='pending_payment' must NOT be processed/shipped."
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "processing",
        "packed",
        "shipped",
        "out_for_delivery",
        "delivered",
        "cancelled",
        "returned"
      ],
      "default": "confirmed",
      "description": "Fulfillment status. IMPORTANT: Do NOT change to 'processing' unless payment_status is 'paid'. Check BOTH payment_status AND status before fulfilling orders."
    },
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "delivery_address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "estimated_delivery": {
      "type": "string",
      "format": "date"
    },
    "tracking_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    },
    "hubtel_transaction_id": {
      "type": "string"
    },
    "hubtel_status": {
      "type": "string",
      "enum": [
        "initiated",
        "pending",
        "successful",
        "failed"
      ],
      "default": "initiated"
    },
    "payment_reference": {
      "type": "string",
      "description": "Unique Hubtel reference used for verification"
    }
  },
  "required": [
    "items",
    "total_amount",
    "customer_name",
    "customer_email",
    "delivery_address"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.customer_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.customer_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}